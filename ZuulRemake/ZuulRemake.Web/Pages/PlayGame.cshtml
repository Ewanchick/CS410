@page
@model ZuulRemake.Web.Pages.PlayGameModel
@{
    ViewData["Title"] = "Play Game";
}
<div class="background">
    <div class="game-container">
        <h1>World of Zuul</h1>
        <div class="game-frame">
            <div class="game-frame-b">
                <div class="viewbox">
                    <img src="@Url.Content(Model.ViewModel.backgroundImageUrl)"
                         onerror="this.src='/images/currentviewplaceholder2.png'" /> 

                    <!--  NOT WORKING:
                        1. tried moving form tag to outside of item-layer div, this didn't fix it.
                           hit F12 to check network, OnPost method is not even being called.
                           there is no pointer cursor so that's one clue i guess
                        2. clicking on item should:
                            A) remove the item from the room -> updated state should reflect a room with no items in it
                            B) add the item to the player inventory -> updated state should reflect an item in the inventory HUD
                    -->
                    <form method="post" asp-page-handler="TakeItem">
                        <div class="item-layer">
                            @if (Model.ViewModel.isLit)
                            {
                                @foreach (var item in Model.ViewModel.items)
                                {
                                    <input type="hidden" name="itemName" value="@item" />
                                    <button type="submit" class="action-button">
                                        <img src="@Url.Content($"~/images/{item.ToLower()}.png")" alt="@item" />
                                    </button>

                                }
                            }
                        </div>
                    </form>


                    <div class="monster-layer">
                        <!--  hide this entire layer if state.monsters is or becomes empty -->
                        @foreach (var mon in Model.ViewModel.monsters)
                        {
                            <img class="monster" src="~/images/@(mon.ToLower()).png" />
                        }
                    </div>


                    <div class="player-layer">
                        <img class="left-hand" src="@Url.Content(Model.ViewModel.LHandUrl)" />
                        <img class="right-hand" src="@Url.Content(Model.ViewModel.RHandUrl)" />
                    </div>


                    <div class="ui-layer">
                        <div class="text-box" id="textBox" onclick="advanceMessage()">
                            <div class="text-content" id="textContent">
                                @foreach (var msg in Model.ViewModel.messages)
                                {
                                    <p>@msg</p>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <div class="hud">
                    <!-- LEFT -->
                    <div class="hud-left">
                        <div class="healthbar-container">
                            HP: @Model.ViewModel.playerHP
                        </div>
                    </div>

                    <!-- CENTER -->
                    <div class="hud-center">
                        <div class="inventory">
                            @foreach (var item in Model.ViewModel.inventory)
                            {
                                <div class="item-boxes">
                                    <img src="~/images/@(item.ToLower()).png" />
                                </div>
                            }
                            @if (Model.ViewModel.inventory.Count() == 0)
                            {
                                <div class="item-boxes">
                                </div>
                            }
                        </div>
                    </div>

                    <!-- RIGHT -->
                    <div class="hud-right">
                        <details class="dropdown">
                            <summary>Move</summary>
                            <div class="content">
                                @foreach (var exit in Model.ViewModel.exits)
                                {
                                    <form method="post" asp-page-handler="Move">
                                        <input type="hidden" name="direction" value="@exit" />
                                        <button type="submit" style="border:none; background:none;">@exit</button>
                                    </form>
                                }
                            </div>
                        </details>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
                document.addEventListener('click', function (e) {
            const openDropdowns = document.querySelectorAll('details.dropdown[open]');

            openDropdowns.forEach(dropdown => {
                if (!dropdown.contains(e.target)) {
                    dropdown.removeAttribute('open');
                }
            });
        });

    </script>

    <script>
             document.getElementById('textBox').addEventListener('click', function() {
            this.classList.add('hidden');
            advanceMessage();
        });
        function advanceMessage() {
            document.getElementById('advanceForm').submit();
        }
    </script>

</div>
