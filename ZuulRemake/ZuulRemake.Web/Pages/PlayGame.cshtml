@page
@model ZuulRemake.Web.Pages.PlayGameModel
@{
    ViewData["Title"] = "Play Game";
}
<div class="background">
    <div class="game-container">
        <h1>World of Zuul</h1>
        <div class="game-frame">
            <div class="game-frame-b">
                <div class="viewbox">
                    <img src="@Url.Content(Model.ViewModel.backgroundImageUrl)"
                         onerror="this.src='/images/currentviewplaceholder2.png'" />
                    <div class="item-layer">
                        @foreach (var item in Model.ViewModel.items)
                        {
                            <form method="post" asp-page-handler="TakeItem">
                                <input type="hidden" name="itemName" value="@item" />
                                <button type="submit" style="border:none; background:none;">
                                    <img src="/images/items/@(item.ToLower()).png" />
                                </button>
                            </form>
                        }

                    </div>


                    <div class="monster-layer">
                        <img class="monster" src="~/images/wmjs.png" />
                    </div>


                    <div class="player-layer"> <!-- change how this is set -->
                        <img class="left-hand" src="~/images/lhand.png" />
                        <img class="right-hand" src="~/images/rhand_sword.png" />
                    </div>


                    <div class="ui-layer">
                        <div class="text-box" id="textBox" onclick="advanceMessage()">
                            <div class="text-content" id="textContent">
                                @foreach (var msg in Model.ViewModel.messages)
                                {
                                    <p>@msg</p>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <div class="hud">

                    <!-- LEFT -->
                    <div class="hud-left">
                        <div class="healthbar-container">
                            HP: @Model.ViewModel.playerHP
                        </div>
                    </div>

                    <!-- CENTER -->
                    <div class="hud-center">
                        <div class="inventory">
                            @foreach (var item in Model.ViewModel.inventory)
                            {
                                <div class="item-boxes">
                                    <img src="~/images/sword.png" />
                                </div>
                            }
                            @if (Model.ViewModel.inventory.Count() == 0)
                            {
                                <div class="item-boxes">
                                </div>
                            }
                        </div>
                    </div>

                    <!-- RIGHT -->
                    <div class="hud-right">
                        <details class="dropdown">
                            <summary>Move</summary>
                            <div class="content">
                                @foreach (var exit in Model.ViewModel.exits)
                                {
                                    <form method="post" asp-page-handler="Move">
                                        <input type="hidden" name="direction" value="@exit" />
                                        <button type="submit" style="border:none; background:none;">@exit</button>
                                    </form>
                                }
                            </div>
                        </details>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
                document.addEventListener('click', function (e) {
            const openDropdowns = document.querySelectorAll('details.dropdown[open]');

            openDropdowns.forEach(dropdown => {
                if (!dropdown.contains(e.target)) {
                    dropdown.removeAttribute('open');
                }
            });
        });

    </script>
    <script>
        function advanceMessage() {
            // hook this to a POST later
        }
    </script>

</div>
