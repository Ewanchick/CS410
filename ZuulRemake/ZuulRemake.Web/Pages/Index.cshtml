@page
@model ZuulRemake.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Play Game";
}

<div class="background">
    <div class="game-container">
        <div class="game-frame">
            <div class="viewbox">
                <img src="~/images/currentviewplaceholder.png"/> <!--- CURRENT ROOM VIEW --->
                <div class="item-layer">
                    <img src=""/> <!--- ITEMS IN THIS ROOM --->
                </div>


                <div class="monster-layer">
                    <img class="monster" src="~/images/monster.png" />
                </div>


                <div class="player-layer">
                    <img class="left-hand" src="~/images/lhand.png" />
                    <img class="right-hand" src="~/images/rhand.png" />
                </div>


                <div class="ui-layer">
                    <div class="text-box hidden" id="textBox">
                        <div class="text-content" id="textContent"></div>
                    </div>
                </div>
            </div>

            <div class="hud">
                <div class="healthbar">
                    <!--- HEALTH BAR --->
                </div>
                <div class="inventory">
                    <div class="item-boxes">
                        <div class="item-box">
                            <img src="~/images/sword.png" />
                        </div>
                        <div class="item-box">
                            <img src="~/images/lantern.png" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
