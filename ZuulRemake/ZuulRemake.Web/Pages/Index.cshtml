@page
@model ZuulRemake.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Play Game";
}


<div class="background">
    <div class="game-container">
        <h1>Whaaaat?!</h1>
        <div class="game-frame">
            <div class="viewbox">
                <img src="~/images/currentviewplaceholder2.png"/> <!--- CURRENT ROOM VIEW --->
                <div class="item-layer">
                    <img src=""/> <!--- ITEMS IN THIS ROOM --->
                </div>


                <div class="monster-layer">
                    <img class="monster" src="~/images/wmjs.png" />
                </div>


                <div class="player-layer">
                    <img class="left-hand" src="~/images/lhand.png" />
                    <img class="right-hand" src="~/images/rhand.png" />
                </div>


                <div class="ui-layer">
                    <div class="text-box" id="textBox">
                        <div class="text-content" id="textContent">
                            <p>What could be in that briefcase? Money, gold, diamonds? I don't think this is about money... 
                                Is it a bomb? If it was, he wouldn't hit me over the head with one. What if it's Archibald's severed head?</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="hud">
                <div class="healthbar">
                    <!--- HEALTH BAR or HP read --->
                </div>
                <div class="inventory">
                    <div class="item-boxes">


                        <div class="item-box">
                            <details class="dropdown">
                                <summary style="list-style: none;">
                                <img src="~/images/sword.png" />
                                </summary>
                                <div class="content">
                                    <a href="#">ATTACK</a>
                                    <a href="#">DROP ITEM</a>
                                </div>
                            </details>
                        </div>

                        


                        <div class="item-box">
                            <details class="dropdown">
                                <summary style="list-style: none;">
                                    <img src="~/images/lantern.png" />
                                </summary>
                                <div class="content">
                                    <a href="#">USE</a>
                                    <a href="#">DROP ITEM</a>
                                </div>
                            </details>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
                document.addEventListener('click', function (e) {
            const openDropdowns = document.querySelectorAll('details.dropdown[open]');

            openDropdowns.forEach(dropdown => {
                if (!dropdown.contains(e.target)) {
                    dropdown.removeAttribute('open');
                }
            });
        });

    </script>
</div>
